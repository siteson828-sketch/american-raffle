generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String    @id @default(cuid())
  email              String    @unique
  name               String?
  password           String?
  image              String?
  role               String    @default("user")
  mustChangePassword Boolean   @default(false)
  trialEndsAt        DateTime?
  referralCode       String    @unique @default(cuid())
  referredById       String?
  referredBy         User?     @relation("Referrals", fields: [referredById], references: [id])
  referrals          User[]    @relation("Referrals")
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  tickets            Ticket[]
  orders             Order[]
  accounts           Account[]
  sessions           Session[]
  referralShares     ReferralShare[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Raffle {
  id                    String           @id @default(cuid())
  title                 String
  description           String
  carMake               String
  carModel              String
  carYear               Int
  carColor              String
  carMsrp               Float
  photos                String
  totalTickets          Int
  soldTickets           Int              @default(0)
  ticketPrice           Float            @default(10.0)
  taxCovered            Boolean          @default(true)
  dealerName            String?
  dealerCity            String?
  dealerState           String?
  dealerStripeAccountId String?
  status                String           @default("active")
  drawDate              DateTime?
  winnerId              String?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  tickets               Ticket[]
  orders                Order[]
  drawingLog            DrawingLog?
  referralConfig        ReferralConfig?
  referralShares        ReferralShare[]
}

model ReferralConfig {
  id                 String  @id @default(cuid())
  raffleId           String  @unique
  raffle             Raffle  @relation(fields: [raffleId], references: [id])
  enabled            Boolean @default(true)
  bonusTicketsPerRef Int     @default(1)
  maxBonusPerUser    Int     @default(0)
  leaderboardEnabled Boolean @default(true)
  topReferrerBonus   Int     @default(0)
}

model ReferralShare {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  raffleId        String
  raffle          Raffle   @relation(fields: [raffleId], references: [id])
  method          String
  convertedUserId String?
  createdAt       DateTime @default(now())
}

model DrawingLog {
  id               String   @id @default(cuid())
  raffleId         String   @unique
  raffle           Raffle   @relation(fields: [raffleId], references: [id])
  winnerUserId     String?
  winnerTicketNum  Int
  totalEntries     Int
  randomSeed       String
  method           String   @default("crypto_random")
  drawnAt          DateTime @default(now())
  drawnByUserId    String
  verificationHash String
  payoutTriggered  Boolean  @default(false)
  payoutAmount     Float?
  stripeTransferId String?
}

model Ticket {
  id         String   @id @default(cuid())
  ticketNum  Int
  raffleId   String
  userId     String
  orderId    String
  isFree     Boolean  @default(false)
  freeReason String?
  createdAt  DateTime @default(now())

  raffle     Raffle   @relation(fields: [raffleId], references: [id])
  user       User     @relation(fields: [userId], references: [id])
  order      Order    @relation(fields: [orderId], references: [id])
}

model Order {
  id              String   @id @default(cuid())
  userId          String
  raffleId        String
  quantity        Int
  amount          Float
  stripePaymentId String?
  status          String   @default("pending")
  createdAt       DateTime @default(now())

  user            User     @relation(fields: [userId], references: [id])
  raffle          Raffle   @relation(fields: [raffleId], references: [id])
  tickets         Ticket[]
}

model Product {
  id            String   @id @default(cuid())
  name          String
  description   String
  price         Float
  image         String
  category      String
  stock         Int      @default(100)
  active        Boolean  @default(true)
  stripePriceId String?
  createdAt     DateTime @default(now())
}
